#!/bin/bash

# 스크립트가 위치한 실제 디렉토리로 이동 (어디서 실행하든 작동하도록 설정)
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$DIR"

echo "=========================================================="
echo "📊 네이버 쇼핑 시장 분석 대시보드를 실행합니다..."
echo "=========================================================="

# 가상 환경(.venv) 존재 여부 체크
if [ -d ".venv" ]; then
    echo "⚙️  가상 환경(.venv)을 활성화하는 중..."
    source .venv/bin/activate
else
    echo "❌ 에러: 가상 환경(.venv)을 찾을 수 없습니다."
    echo "프로젝트 폴더 내에 .venv 폴더가 있는지 확인해 주세요."
    read -p "엔터를 누르면 창이 닫힙니다..."
    exit 1
fi

# Streamlit 설치 여부 체크 및 필요시 의존성 설치
if ! command -v streamlit &> /dev/null; then
    echo "⚙️  필수 라이브러리가 설치되어 있지 않습니다. 설치를 시작합니다..."
    pip install -r requirements.txt
fi

echo "🚀 대시보드 서버를 시작합니다..."
echo "잠시 후 웹 브라우저 창이 자동으로 열립니다."
echo "----------------------------------------------------------"
echo "💡 대시보드를 종료하려면 이 터미널 창을 닫거나"
echo "   터미널 창에서 [Control + C] 키를 누르세요."
echo "=========================================================="

streamlit run dashboard.py

# 실행 실패 또는 정상 종료 시 대기
read -p "대시보드가 종료되었습니다. 엔터를 누르면 창이 닫힙니다..."
